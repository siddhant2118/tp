@startuml ExamSessionSequence
actor User
participant ":ExamSession" as ES
participant ":QuestionBank" as QB
participant ":QuestionInteraction" as QI
participant ":Ui" as UI
participant ":ExamResult" as ER

User -> ES : startInteractive()
ES -> QB : getTopics()
ES -> ES : listTopics()
activate ES
deactivate ES
ES -> UI : readLine("Select topic (number or name): ")
UI --> ES : topicSelection

ES -> UI : readLine("How many questions? (1-N, default: all): ")
UI --> ES : countInput

ES -> QB : getQuestions(topic, count, false)
QB --> ES : questions

loop for each question
    alt MCQ or FITB
        ES -> QI : presentQuestionWithResult(q, index, total, result)
        QI -> UI : println(question.present())
        QI -> UI : readLine("Your answer: ")
        UI --> QI : userAnswer
        QI -> QI : question.checkAnswer(userAnswer)
        activate QI
        deactivate QI
        QI -> ER : addResult(question, answer, correct)
    else PRAC
        ES -> ES : handlePracQuestion(q)
        activate ES
        note right
            Creates temp VFS + ShellSession.
            User types commands until "exit".
            q.checkVfs(tempVfs) verifies result.
        end note
        deactivate ES
        ES -> ER : addResult(question, "", correct)
    end
end

ES -> ER : display()
ER --> ES : "Score: 7/10 (70%)"
ES -> UI : println(result)
@enduml

@startuml ExamClassDiagram
skinparam classAttributeIconSize 0

abstract class Question {
    # type : QuestionType
    # difficulty : Difficulty
    # questionText : String
    # explanation : String
    + {abstract} present() : String
    + {abstract} checkAnswer(answer) : boolean
    + formatHeader() : String
}

enum "Question.QuestionType" as QT {
    MCQ
    FITB
    PRAC
}

enum "Question.Difficulty" as QD {
    EASY
    MEDIUM
    HARD
}

class McqQuestion extends Question {
    - options : LinkedHashMap<Character, String>
    - correctAnswer : char
}

class FitbQuestion extends Question {
    - acceptedAnswers : List<String>
}

class PracQuestion extends Question {
    - checkpoints : List<Checkpoint>
    - setupItems : List<SetupItem>
    + checkVfs(vfs) : boolean
    + applySetup(vfs)
}

class Checkpoint {
    - path : String
    - expectedType : NodeType
    - expectedContent : String
    - expectedPermission : String
    + matches(vfs) : boolean
}

enum "Checkpoint.NodeType" as NodeType {
    DIR
    FILE
    NOT_EXISTS
    CONTENT_EQUALS
    PERM
}

class ExamSession {
    - questionBank : QuestionBank
    - ui : Ui
    - vfsFactory : Supplier<VirtualFileSystem>
    - questionInteraction : QuestionInteraction
    - randomQuestionMode : RandomQuestionMode
    + startInteractive()
    + startWithArgs(topic, count, random)
    + runOneRandom()
    + listTopics()
    - handlePracQuestion(q) : boolean
}

' Note: VirtualFileSystem lives in linuxlingo.shell.vfs
class VirtualFileSystem

class QuestionInteraction {
    - ui : Ui
    + presentQuestionWithResult(q, index, total, result)
    + presentSingleQuestion(q, index, total) : boolean
}

class RandomQuestionMode {
    - questionBank : QuestionBank
    - ui : Ui
    - interaction : QuestionInteraction
    - pracHandler : PracHandler
    + runOneRandom()
}

class QuestionBank {
    - topics : Map<String, List<Question>>
    + load(directory)
    + getTopics() : List<String>
    + getQuestions(...) : List<Question>
    + getRandomQuestion() : Question
}

class ExamResult {
    - results : List<QuestionResult>
    + addResult(...)
    + getScore() : int
    + display() : String
}

ExamSession --> QuestionBank : queries
ExamSession --> ExamResult : accumulates
ExamSession --> QuestionInteraction : delegates
ExamSession --> RandomQuestionMode : delegates
ExamSession ..> ShellSession : creates temp\n(for PRAC)
QuestionBank --> "*" Question : stores
RandomQuestionMode --> QuestionInteraction : uses
PracQuestion --> "*" Checkpoint : verified by
Question --> QT
Question --> QD
Checkpoint --> NodeType
@enduml

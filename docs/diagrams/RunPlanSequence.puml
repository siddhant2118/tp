@startuml RunPlanSequence
hide footbox
participant ":ShellSession" as SS
participant ":CommandRegistry" as CR
participant ":Command" as CMD
participant ":VirtualFileSystem" as VFS
participant ":Ui" as UI

loop for each Segment i in ParsedPlan

  SS -> SS : check preceding operator
  activate SS
  note right
    AND (&&): skip if last exit code != 0
    OR (||): skip if last exit code == 0
    PIPE: forward previous stdout as stdin
    SEMICOLON: always run
  end note
  deactivate SS

  SS -> SS : resolveStdin(segment, pipedStdin)
    activate SS
    note right
      inputRedirect present → VFS.readFile()
      else use pipedStdin
    end note
    deactivate SS

  SS -> SS : prepareArgs(segment)
    activate SS
    note right
      resolveAlias → expandCombinedFlags
      → expandGlobs → expandVariables
    end note
    deactivate SS

  SS -> CR : get(resolvedName)

  alt command found
    SS -> CMD : execute(session, args, stdin)
    CMD --> SS : CommandResult

    opt segment has output redirect
      SS -> VFS : writeFile(target, stdout, append)
    end

  else command not found
    SS -> SS : suggestCommand(name)
    activate SS
    deactivate SS
    SS -> UI : println(error + suggestion)
    SS -> SS : setLastExitCode(127)
    activate SS
    deactivate SS
  end

end
@enduml

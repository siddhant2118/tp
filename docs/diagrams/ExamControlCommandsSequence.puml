@startuml
' Exam session: non-PRAC question interaction with quit/abort
' This diagram is aligned with:
' - linuxlingo.exam.ExamSession#runExam(...)
' - linuxlingo.exam.QuestionInteraction#presentQuestionWithResult(...)

title Exam session – In-exam control commands (quit / abort)

autonumber

participant "ExamSession" as ES
participant "QuestionInteraction" as QI
participant "Ui" as UI
participant "Question" as Q
participant "ExamResult" as ER


ES -> QI : presentQuestionWithResult(Q, index, total, ER)
activate QI

QI -> UI : println("[Q"+index+"/"+total+"] " + Q.present())
QI -> UI : readLine("Your answer: ")
UI --> QI : userAnswer

alt userAnswer != null AND userAnswer.trim().equalsIgnoreCase("abort")
  QI -> QI : examAborted = true
  QI -> UI : println("Exam aborted.")
  QI --> ES : return false
  deactivate QI

  ES -> ES : break question loop

else userAnswer == null OR userAnswer.trim().equalsIgnoreCase("quit")
  QI -> ER : addResult(Q, "", false)
  QI --> ES : return true
  deactivate QI

  ES -> ES : continue to next question

else normal answer
  QI -> Q : checkAnswer(userAnswer)
  Q --> QI : correct?

  alt correct
    QI -> UI : println("Correct!")
  else incorrect
    QI -> UI : println("Incorrect.")
  end

  QI -> UI : println("Explanation: " + Q.getExplanation())
  QI -> ER : addResult(Q, userAnswer, correct)
  QI --> ES : return true
  deactivate QI

  ES -> ES : continue to next question
end

@enduml

